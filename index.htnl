                macros: { cal: 1075, pro: 107, carb: 58, fat: 47 },
                meals: [
                    { offsetHours: 0.5, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת בוקר", protein: 18, desc: "2 ביצים מקושקשות עם כף אחת גבינת מוצרלה 5% מגוררת מומסת בפנים.", tip: "המוצרלה המומסת קושרת את הביצים והופכת אותן למרקם גמיש וקטיפתי שאינו יבש כלל." },
                    { offsetHours: 3.0, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת ביניים בוקר", protein: 20, desc: "גביע יוגורט חלבון GO/PRO בטעם טבעי או פירות יער.", tip: "מנות יוגורט מוכנות הן פתרון מדהים לאכילה נוחה מחוץ לבית כשאתה בלימודים או בסידורים." },
                    { offsetHours: 6.0, kosherType: "parve", kosherLabel: "פרווה", name: "ארוחת צהריים", protein: 22, desc: "200 גרם קוביות טופו יציב מוקפצות במחבת עם כף שמן שומשום ורוטב סויה דל נתרן + כוס פרחי ברוקולי מאודים ורכים מאוד.", tip: "השרה את הטופו ברוטב סויה 10 דקות לפני ההקפצה כדי שיספוג את כל הטעם לתוכו." },
                    { offsetHours: 8.5, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת ביניים אחה\"צ", protein: 24, desc: "יוגורט GO/PRO חלבון לבן פשוט עם כפית אחת קטנה חמאת שקדים טבעית.", tip: "חמאת שקדים משתלבת נהדר ביוגורט ומעניקה לו מתיקות מעודנת של מרציפן." },
                    { offsetHours: 11.0, kosherType: "parve", kosherLabel: "פרווה", name: "ארוחת ערב", protein: 23, desc: "שקשוקת טונה מהירה: ביצה אחת מבושלת היטב ברוטב עגבניות יחד עם חצי קופסת טונה מעורבבת בתוך הרוטב.", tip: "הטונה סופגת את מיצי העגבניות והופכת לרכה וטעימה במיוחד בליווי חצי פרוסת לחם מלא קלוי." }
                ]
            },
            {
                name: "תפריט יב' - דג אמנון ופירה בטטה קטיפתי",
                macros: { cal: 920, pro: 106, carb: 48, fat: 35 },
                meals: [
                    { offsetHours: 0.5, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת בוקר", protein: 34, desc: "שייק חלבון: כוס חלב 3% מועשר + כף מדידה אחת של אבקת חלבון מי גבינה + חצי בננה קטנה.", tip: "שתיית שייק חלבון בבוקר היא הדרך הקלה והמהירה ביותר להתחיל את היום עם כמות חלבון עצומה בלי להעמיס נפח על הקיבה." },
                    { offsetHours: 3.0, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת ביניים בוקר", protein: 15, desc: "חצי גביע קוטג' 5% עם רצועות דקות של מלפפון ללא קליפה.", tip: "הקוטג' מכיל חלבון קזאין שמתעכל לאט ומזין את השרירים לאורך מספר שעות." },
                    { offsetHours: 6.0, kosherType: "parve", kosherLabel: "פרווה", name: "ארוחת צהריים", protein: 25, desc: "120 גרם פילה אמנון (מושט) אפוי בתנור עם שמן זית, פפריקה ומלח + 3 כפות פירה בטטה רך.", tip: "פזר מעט כמון על הדג לפני האפייה כדי להעניק לו ארומה מזרח תיכונית משגעת." },
                    { offsetHours: 8.5, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת ביניים אחה\"צ", protein: 12, desc: "2 פרוסות גבינה צהובה 9% מגולגלות סביב מקל מלפפון קלוף.", tip: "חטיף חלבון מהיר ונוח לביצוע ללא בישול כלל." },
                    { offsetHours: 11.0, kosherType: "parve", kosherLabel: "פרווה", name: "ארוחת ערב", protein: 20, desc: "קופסת טונה קטנה מסוננת מעורבבת עם רבע אבוקדו מועך ומעט בצל ירוק קצוץ דק.", tip: "הבצל הירוק נותן בעיטה מעולה של טעם רענן לטונה הפשוטה." }
                ]
            }
        ];

        let timerInterval = null;
        let timerSeconds = 30 * 60; // 30 minutes in seconds
        let timerRunning = false;
        let currentActiveMenuIndex = -1;
        let selectedMealsState = {}; // Keeps track of checked meals for the current menu
        let globalWakeUpTime = "08:00"; // Default wake-up time

        function toggleWaterTimer() {
            const btn = document.getElementById('startTimerBtn');
            const display = document.getElementById('timerDisplay');
            
            if (timerRunning) {
                // Stop timer
                clearInterval(timerInterval);
                timerRunning = false;
                timerSeconds = 30 * 60;
                btn.innerHTML = `<i data-lucide="timer" class="w-3.5 h-3.5"></i><span>הפעל</span>`;
                display.innerText = "הפעל טיימר של 30 דקות בסיום הביס";
                display.className = "text-xs text-stone-500";
                lucide.createIcons();
            } else {
                // Start timer
                timerRunning = true;
                btn.innerHTML = `<i data-lucide="circle-stop" class="w-3.5 h-3.5"></i><span>עצור</span>`;
                btn.classList.add('bg-red-600', 'hover:bg-red-700');
                btn.classList.remove('bg-blue-600', 'hover:bg-blue-700');
                lucide.createIcons();
                
                timerInterval = setInterval(() => {
                    timerSeconds--;
                    let mins = Math.floor(timerSeconds / 60);
                    let secs = timerSeconds % 60;
                    display.innerText = `מותר לשתות בעוד: ${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')} דקות`;
                    display.className = "text-xs text-blue-600 font-bold animate-pulse";
                    
                    if (timerSeconds <= 0) {
                        clearInterval(timerInterval);
                        display.innerText = "מעולה! מותר לך לשתות כעת! 💧";
                        display.className = "text-xs text-emerald-600 font-extrabold";
                        btn.innerHTML = `<i data-lucide="check" class="w-3.5 h-3.5"></i><span>הושלם</span>`;
                        btn.classList.remove('bg-red-600', 'hover:bg-red-700');
                        btn.classList.add('bg-emerald-600');
                        lucide.createIcons();
                    }
                }, 1000);
            }
        }

        function updateWakeUpTime(timeVal) {
            globalWakeUpTime = timeVal;
            if (currentActiveMenuIndex !== -1) {
                renderMenu(currentActiveMenuIndex);
            }
        }

        function setToNowTime() {
            const now = new Date();
            const hours = now.getHours().toString().padStart(2, '0');
            const minutes = now.getMinutes().toString().padStart(2, '0');
            const timeStr = `${hours}:${minutes}`;
            document.getElementById('wakeUpTimeInput').value = timeStr;
            updateWakeUpTime(timeStr);
        }

        function calculateMealTime(wakeTimeStr, offsetHours) {
            const [wHours, wMinutes] = wakeTimeStr.split(':').map(Number);
            const wakeDate = new Date();
            wakeDate.setHours(wHours, wMinutes, 0, 0);
            
            // Add offset hours
            const offsetMs = offsetHours * 60 * 60 * 1000;
            const mealDate = new Date(wakeDate.getTime() + offsetMs);
            
            const hours = mealDate.getHours().toString().padStart(2, '0');
            const minutes = mealDate.getMinutes().toString().padStart(2, '0');
            return `${hours}:${minutes}`;
        }

        window.onload = function() {
            const selectEl = document.getElementById('directMenuSelect');
            menus.forEach((m, idx) => {
                const opt = document.createElement('option');
                opt.value = idx;
                opt.innerText = m.name;
                selectEl.appendChild(opt);
            });
            
            // Generate icons
            lucide.createIcons();
        }

        function updateProteinTracker() {
            const menu = menus[currentActiveMenuIndex];
            if (!menu) return;

            let totalTarget = menu.macros.pro;
            let consumed = 0;

            menu.meals.forEach((meal, idx) => {
                const key = `${currentActiveMenuIndex}_${idx}`;
                if (selectedMealsState[key]) {
                    consumed += meal.protein;
                }
            });

            // Update stats text
            document.getElementById('trackerStats').innerText = `נצרך: ${consumed} גרם מתוך ${totalTarget} גרם חלבון`;
            
            // Update visual progress bar width
            const percentage = Math.min((consumed / totalTarget) * 100, 100);
            document.getElementById('trackerProgressBar').style.width = percentage + '%';
        }

        function toggleMealCheck(mealIdx, protein) {
            const key = `${currentActiveMenuIndex}_${mealIdx}`;
            const checkbox = document.getElementById(`chk_${mealIdx}`);
            const mealCard = document.getElementById(`mealCard_${mealIdx}`);
            
            if (checkbox.checked) {
                selectedMealsState[key] = true;
                mealCard.classList.add('bg-emerald-50/40', 'border-emerald-200');
                mealCard.classList.remove('border-stone-100');
            } else {
                selectedMealsState[key] = false;
                mealCard.classList.remove('bg-emerald-50/40', 'border-emerald-200');
                mealCard.classList.add('border-stone-100');
            }

            updateProteinTracker();
        }

        function renderMenu(menuIndex) {
            currentActiveMenuIndex = menuIndex;
            const menu = menus[menuIndex];
            const outputCont = document.getElementById('outputContainer');
            
            // Fade-in animation helper
            outputCont.classList.remove('hidden');
            outputCont.classList.add('opacity-0', 'scale-95');
            
            setTimeout(() => {
                document.getElementById('menuName').innerText = menu.name;
                
                // Set Macros in visual header
                document.getElementById('cal').innerText = menu.macros.cal;
                document.getElementById('pro').innerText = menu.macros.pro + 'g';
                document.getElementById('carb').innerText = menu.macros.carb + 'g';
                document.getElementById('fat').innerText = menu.macros.fat + 'g';

                // Update Visual Macro Bars (Scale from 0 to 100%)
                document.getElementById('calBar').style.width = Math.min((menu.macros.cal / 1200) * 100, 100) + '%';
                document.getElementById('proBar').style.width = Math.min((menu.macros.pro / 120) * 100, 100) + '%';
                document.getElementById('carbBar').style.width = Math.min((menu.macros.carb / 100) * 100, 100) + '%';
                document.getElementById('fatBar').style.width = Math.min((menu.macros.fat / 60) * 100, 100) + '%';

                // Reset tracker UI for this menu
                updateProteinTracker();

                // Build Meals List
                const mealsContainer = document.getElementById('mealsContainer');
                mealsContainer.innerHTML = '';

                menu.meals.forEach((meal, idx) => {
                    const kosherStyles = {
                        dairy: { bg: 'bg-blue-50', text: 'text-blue-700', border: 'border-blue-200' },
                        meat: { bg: 'bg-red-50', text: 'text-red-700', border: 'border-red-200' },
                        parve: { bg: 'bg-emerald-50', text: 'text-emerald-700', border: 'border-emerald-200' }
                    };
                    const styling = kosherStyles[meal.kosherType] || kosherStyles.parve;
                    const calculatedTime = calculateMealTime(globalWakeUpTime, meal.offsetHours);
                    const key = `${menuIndex}_${idx}`;
                    const isChecked = selectedMealsState[key] ? 'checked' : '';
                    const highlightClass = isChecked ? 'bg-emerald-50/40 border-emerald-200' : 'border-stone-100';

                    const mealDiv = document.createElement('div');
                    mealDiv.id = `mealCard_${idx}`;
                    mealDiv.className = `relative pr-2 p-3 rounded-2xl border transition duration-150 ${highlightClass}`;
                    mealDiv.innerHTML = `
                        <!-- Timeline circle dot -->
                        <div class="absolute right-[-27px] top-4 w-3 h-3 rounded-full bg-brand-500 border-2 border-white shadow-sm"></div>
                        
                        <div class="flex items-start gap-3">
                            <!-- Custom Checklist Checkbox -->
                            <div class="flex items-center h-5 mt-1">
                                <input id="chk_${idx}" type="checkbox" ${isChecked} onchange="toggleMealCheck(${idx}, ${meal.protein})" class="w-5 h-5 text-emerald-600 bg-stone-100 border-stone-300 rounded focus:ring-emerald-500 cursor-pointer">
                            </div>
                            
                            <div class="flex-1">
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-1">
                                    <div class="flex items-center gap-2">
                                        <span class="px-2 py-0.5 text-[10px] font-extrabold rounded-md ${styling.bg} ${styling.text} border ${styling.border}">
                                            ${meal.kosherLabel}
                                        </span>
                                        <span class="text-xs font-bold text-stone-400">${calculatedTime}</span>
                                        <span class="text-xs font-extrabold text-emerald-600">(${meal.protein}g חלבון)</span>
                                    </div>
                                    <h4 class="text-sm font-extrabold text-stone-800">${meal.name || 'ארוחה קלה'}</h4>
                                </div>
                                <p class="text-stone-600 text-sm leading-relaxed">${meal.desc}</p>
                                
                                <!-- Chef cooking tip -->
                                <div class="mt-2 p-2 bg-amber-50/50 rounded-lg border border-amber-100/60 flex items-start gap-1.5 text-xs text-amber-800">
                                    <i data-lucide="chef-hat" class="w-4 h-4 text-amber-600 shrink-0 mt-0.5"></i>
                                    <div><strong>טיפ להכנה מנצחת:</strong> ${meal.tip}</div>
                                </div>
                            </div>
                        </div>
                    `;
                    mealsContainer.appendChild(mealDiv);
                });

                outputCont.classList.remove('opacity-0', 'scale-95');
                outputCont.classList.add('opacity-100', 'scale-100');
                
                // Trigger dynamic icons render
                lucide.createIcons();
                updateProteinTracker();
                
                // Smooth scroll to output container
                outputCont.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 150);
        }

        function rollMenu() {
            let randomIndex;
            do {
                randomIndex = Math.floor(Math.random() * menus.length);
            } while (randomIndex === currentActiveMenuIndex && menus.length > 1);

            currentActiveMenuIndex = randomIndex;
            
            // Sync dropdown select visual
            document.getElementById('directMenuSelect').value = randomIndex;
            
            renderMenu(randomIndex);
        }

        function loadSelectedMenu(indexVal) {
            const index = parseInt(indexVal);
            if (!isNaN(index)) {
                currentActiveMenuIndex = index;
                renderMenu(index);
            }
        }
    </script>
</body>
</html>
