                "מערכת הבנויה בארכיטקטורת Client-Server שבה הממשק מוצג בדפדפן הלקוח.",
                "שירות הזמין דרך רשת האינטרנט ואינו מצריך התקנת תוכנה ייעודית על המחשב המקומי.",
                "תוכנה הפועלת על בסיס פרוטוקול HTTP תוך שימוש בדפדפן כצד לקוח קצה."
            ]
        }
    ];

    // פונקציה לערבוב מערך (לערבוב התשובות והשאלות)
    function shuffleArray(array) {
        for (let i = array.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [array[i], array[j]] = [array[j], array[i]];
        }
    }
    
    // נערבב גם את סדר השאלות כדי שהתרגול יהיה אקראי
    shuffleArray(questions);

    const quizContainer = document.getElementById('quiz-container');
    const scoreElement = document.getElementById('score');
    let currentScore = 0;

    questions.forEach((q, index) => {
        // יצירת הכרטיסייה לכל שאלה
        const card = document.createElement('div');
        card.className = 'question-card';
        
        const qTitle = document.createElement('span');
        qTitle.className = 'q-number';
        qTitle.innerText = `שאלה ${index + 1} מתוך ${questions.length}`;
        
        const qText = document.createElement('h3');
        qText.className = 'q-text';
        qText.innerText = q.text;

        const optionsList = document.createElement('div');
        optionsList.className = 'options-list';

        // העתקת האופציות וערבוב שלהן שלא יהיו באותו סדר תמיד
        const shuffledOptions = [...q.options];
        shuffleArray(shuffledOptions);

        // יצירת תיבת ההסבר (מוסתרת בהתחלה)
        const explanationBox = document.createElement('div');
        explanationBox.className = 'explanation-box';
        
        const explanationTitle = document.createElement('div');
        explanationTitle.className = 'explanation-title';
        explanationTitle.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg> הסבר מעמיק:`;
        
        const explanationText = document.createElement('div');
        explanationText.className = 'explanation-text';
        explanationText.innerText = q.explanation;
        
        const altAnsTitle = document.createElement('div');
        altAnsTitle.className = 'alt-answers-title';
        altAnsTitle.innerText = "ניסוחים נוספים שיכולים להיות התשובה הנכונה במבחן:";
        
        const altAnsList = document.createElement('ul');
        altAnsList.className = 'alt-answers-list';
        q.altAnswers.forEach(ans => {
            const li = document.createElement('li');
            li.innerText = ans;
            altAnsList.appendChild(li);
        });

        explanationBox.appendChild(explanationTitle);
        explanationBox.appendChild(explanationText);
        explanationBox.appendChild(altAnsTitle);
        explanationBox.appendChild(altAnsList);

        shuffledOptions.forEach(opt => {
            const btn = document.createElement('button');
            btn.className = 'option-btn';
            btn.innerText = opt.text;
            
            btn.addEventListener('click', () => {
                // נעילת כל הכפתורים בשאלה זו בלבד
                const allButtons = optionsList.querySelectorAll('.option-btn');
                allButtons.forEach(b => b.disabled = true);

                if (opt.correct) {
                    btn.classList.add('correct');
                    currentScore++;
                    scoreElement.innerText = currentScore;
                } else {
                    btn.classList.add('wrong');
                    // מציאת התשובה הנכונה והדגשתה
                    allButtons.forEach(b => {
                        if (shuffledOptions.find(o => o.text === b.innerText).correct) {
                            b.classList.add('correct');
                        }
                    });
                }
                
                // חשיפת ההסבר
                explanationBox.classList.add('show');
            });

            optionsList.appendChild(btn);
        });

        card.appendChild(qTitle);
        card.appendChild(qText);
        card.appendChild(optionsList);
        card.appendChild(explanationBox);
        
        quizContainer.appendChild(card);
    });
</script>
</body>
</html>
