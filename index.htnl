<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>קובי - תפריט מנצח לאחר קיצור קיבה</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Heebo & Assistant for modern Hebrew typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600;700;800&family=Heebo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <!-- Lucide Icons via CDN for beautiful glyphs -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Assistant', 'Heebo', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f4f7f5',
                            100: '#e5ebe6',
                            500: '#4a6b53', // Sage Green primary
                            600: '#3e5945',
                            700: '#2f4334',
                            deep: '#1e2d22',
                        },
                        kosher: {
                            dairy: '#3b82f6', // Blue
                            meat: '#ef4444',  // Red
                            parve: '#10b981'  // Green
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background: linear-gradient(135deg, #f3f6f4 0%, #e9efe9 100%);
            min-height: 100vh;
        }
        /* Custom scrollbar for beautiful menus */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="font-sans antialiased text-stone-800 pb-16">

    <!-- Top Decorative bar -->
    <div class="w-full h-2 bg-gradient-to-r from-emerald-600 via-amber-500 to-emerald-800"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6">
        
        <!-- Header Section -->
        <header class="text-center my-8 md:my-12">
            <div class="inline-flex items-center justify-center p-3 bg-brand-500/10 rounded-full mb-4">
                <i data-lucide="utensils-cross" class="w-8 h-8 text-brand-500"></i>
            </div>
            <h1 class="text-3xl md:text-4xl font-extrabold text-brand-deep tracking-tight">התפריט הבריא של קובי</h1>
            <p class="text-stone-500 mt-2 text-md md:text-lg font-medium max-w-md mx-auto">
                מחולל תפריטים מועשרי חלבון (95g+), מותאמים אישית לבני 24 שמתאמנים
            </p>
        </header>

        <!-- Dynamic Wake-up Time Configuration Card -->
        <div class="bg-white rounded-3xl p-6 shadow-md border border-stone-100 mb-6 transition-all duration-300">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <div class="p-2.5 bg-amber-500/10 text-amber-600 rounded-2xl">
                        <i data-lucide="alarm-clock" class="w-6 h-6 animate-pulse"></i>
                    </div>
                    <div class="text-right">
                        <h3 class="font-extrabold text-stone-800 text-base">מתי התעוררת היום?</h3>
                        <p class="text-xs text-stone-500">שעות הארוחות יתעדכנו אוטומטית לפי שעת היקיצה שלך</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <input type="time" id="wakeUpTimeInput" value="08:00" onchange="updateWakeUpTime(this.value)" class="bg-stone-50 border border-stone-200 text-stone-800 rounded-xl p-2.5 font-bold text-base outline-none focus:ring-2 focus:ring-brand-500 transition cursor-pointer">
                    <button onclick="setToNowTime()" class="px-3 py-2.5 bg-stone-100 hover:bg-stone-200 text-stone-700 font-bold rounded-xl text-xs transition active:scale-95 flex items-center gap-1">
                        <i data-lucide="clock" class="w-4 h-4"></i>
                        <span>עכשיו</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Quick Info Banner -->
        <div class="bg-white/80 backdrop-blur-sm border border-brand-100 rounded-2xl p-4 mb-8 shadow-sm flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-amber-500/10 text-amber-600 rounded-xl">
                    <i data-lucide="shield-check" class="w-5 h-5"></i>
                </div>
                <div class="text-right">
                    <h4 class="font-bold text-stone-800 text-sm">הפרדת בשר וחלב מובנית</h4>
                    <p class="text-xs text-stone-500">תפריטים כשרים המותאמים בדיוק לאימונים שלך</p>
                </div>
            </div>
            
            <div class="h-px w-full sm:h-8 sm:w-px bg-stone-200"></div>

            <!-- Bariatric Hydration Helper -->
            <div id="waterTimerWidget" class="flex items-center justify-between gap-4 w-full sm:w-auto">
                <div class="flex items-center gap-2">
                    <div class="p-2 bg-blue-500/10 text-blue-600 rounded-xl">
                        <i data-lucide="droplet" class="w-5 h-5"></i>
                    </div>
                    <div class="text-right">
                        <h4 class="font-bold text-stone-800 text-sm">הפרדת נוזלים מאוכל</h4>
                        <p id="timerDisplay" class="text-xs text-stone-500">הפעל טיימר של 30 דקות בסיום הביס</p>
                    </div>
                </div>
                <button id="startTimerBtn" onclick="toggleWaterTimer()" class="px-4 py-1.5 bg-blue-600 text-white font-bold rounded-lg text-xs hover:bg-blue-700 transition active:scale-95 flex items-center gap-1">
                    <i data-lucide="timer" class="w-3.5 h-3.5"></i>
                    <span>הפעל</span>
                </button>
            </div>
        </div>

        <!-- Action / Interactive Control Hub -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            
            <!-- Quick Menu Selector Card -->
            <div class="bg-white rounded-3xl p-6 shadow-md border border-stone-100 flex flex-col justify-between h-full">
                <div>
                    <h3 class="text-lg font-bold text-brand-deep flex items-center gap-2 mb-2">
                        <i data-lucide="bookmark-check" class="w-5 h-5 text-brand-500"></i>
                        בחירה מהירה
                    </h3>
                    <p class="text-stone-500 text-sm mb-4">מעדיף לא להגריל? בחר ישירות את אחד מעשרת התפריטים המועשרים:</p>
                </div>
                <select id="directMenuSelect" onchange="loadSelectedMenu(this.value)" class="w-full bg-stone-50 border border-stone-200 text-stone-800 rounded-xl p-3 font-semibold text-sm outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition cursor-pointer">
                    <option value="" disabled selected>-- בחר תפריט --</option>
                    <!-- Options loaded dynamically -->
                </select>
            </div>

            <!-- Big Interactive Roll Button Card -->
            <div class="bg-gradient-to-br from-brand-500 to-brand-700 rounded-3xl p-6 shadow-xl flex flex-col items-center justify-center text-center text-white md:col-span-2 group relative overflow-hidden">
                <div class="absolute -right-10 -bottom-10 opacity-10 pointer-events-none transition-transform duration-700 group-hover:scale-125">
                    <i data-lucide="dices" class="w-48 h-48"></i>
                </div>
                <i data-lucide="sparkles" class="w-8 h-8 text-amber-300 mb-2 animate-bounce"></i>
                <h2 class="text-xl font-extrabold mb-1">לא יודע מה בא לך לאכול היום?</h2>
                <p class="text-brand-100/90 text-sm max-w-sm mb-5">ניתן למערכת לבחור בשבילך תפריט יומי עשיר במיוחד בחלבון וקל לעיכול!</p>
                <button onclick="rollMenu()" class="px-8 py-3.5 bg-amber-400 text-brand-deep font-black rounded-full shadow-lg hover:bg-amber-300 transition duration-300 transform hover:scale-105 active:scale-95 flex items-center gap-2 text-md">
                    <i data-lucide="dices" class="w-5 h-5"></i>
                    <span>הגרל לי תפריט יומי</span>
                </button>
            </div>
        </div>

        <!-- Output Main Screen Card -->
        <div id="outputContainer" class="hidden">
            <div id="menuCard" class="bg-white rounded-3xl shadow-xl border border-stone-100 overflow-hidden transform transition-all duration-300">
                
                <!-- Card Header -->
                <div class="bg-gradient-to-r from-stone-900 to-brand-deep p-6 text-white flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                    <div class="flex items-center gap-3">
                        <div class="p-3 bg-brand-500/20 rounded-2xl">
                            <i data-lucide="heart-pulse" class="w-6 h-6 text-amber-400"></i>
                        </div>
                        <div>
                            <span class="text-xs font-bold text-amber-400 uppercase tracking-widest">נבחר עבורך</span>
                            <h2 id="menuName" class="text-xl font-extrabold mt-0.5">שם התפריט שיופיע</h2>
                        </div>
                    </div>
                    <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/10 rounded-full text-xs font-bold border border-white/20">
                        <i data-lucide="award" class="w-3.5 h-3.5 text-amber-300"></i>
                        <span>חלבון מוגבר למתאמנים</span>
                    </div>
                </div>

                <!-- Macro Nutrients Dash -->
                <div class="bg-stone-50 border-b border-stone-100 p-6">
                    <h4 class="text-stone-400 text-xs font-bold uppercase tracking-wider mb-4 text-center">ערכים תזונתיים משוערכים ליום שלם</h4>
                    <div class="grid grid-cols-4 gap-4 mb-6">
                        
                        <!-- Calories -->
                        <div class="bg-white p-3 rounded-2xl shadow-sm border border-stone-100 text-center">
                            <span id="cal" class="block text-xl sm:text-2xl font-extrabold text-stone-800 font-sans">0</span>
                            <span class="text-[10px] sm:text-xs font-bold text-stone-400 block mt-1">קלוריות</span>
                            <div class="w-full bg-stone-100 h-1.5 rounded-full mt-2 overflow-hidden">
                                <div id="calBar" class="bg-amber-400 h-full rounded-full transition-all duration-500" style="width: 0%"></div>
                            </div>
                        </div>

                        <!-- Protein Target -->
                        <div class="bg-white p-3 rounded-2xl shadow-sm border border-stone-100 text-center">
                            <span id="pro" class="block text-xl sm:text-2xl font-extrabold text-emerald-600 font-sans">0</span>
                            <span class="text-[10px] sm:text-xs font-bold text-stone-400 block mt-1">חלבון יעד</span>
                            <div class="w-full bg-stone-100 h-1.5 rounded-full mt-2 overflow-hidden">
                                <div id="proBar" class="bg-emerald-500 h-full rounded-full transition-all duration-500" style="width: 0%"></div>
                            </div>
                        </div>

                        <!-- Carbs -->
                        <div class="bg-white p-3 rounded-2xl shadow-sm border border-stone-100 text-center">
                            <span id="carb" class="block text-xl sm:text-2xl font-extrabold text-blue-600 font-sans">0</span>
                            <span class="text-[10px] sm:text-xs font-bold text-stone-400 block mt-1">פחמימות</span>
                            <div class="w-full bg-stone-100 h-1.5 rounded-full mt-2 overflow-hidden">
                                <div id="carbBar" class="bg-blue-500 h-full rounded-full transition-all duration-500" style="width: 0%"></div>
                            </div>
                        </div>

                        <!-- Fat -->
                        <div class="bg-white p-3 rounded-2xl shadow-sm border border-stone-100 text-center">
                            <span id="fat" class="block text-xl sm:text-2xl font-extrabold text-purple-600 font-sans">0</span>
                            <span class="text-[10px] sm:text-xs font-bold text-stone-400 block mt-1">שומן</span>
                            <div class="w-full bg-stone-100 h-1.5 rounded-full mt-2 overflow-hidden">
                                <div id="fatBar" class="bg-purple-500 h-full rounded-full transition-all duration-500" style="width: 0%"></div>
                            </div>
                        </div>

                    </div>

                    <!-- Interactive Protein Tracker Box -->
                    <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-4">
                        <div class="flex items-center justify-between mb-2">
                            <div class="flex items-center gap-2">
                                <i data-lucide="check-square" class="w-5 h-5 text-emerald-600"></i>
                                <span class="font-bold text-stone-800 text-sm">מד חלבון יומי דינמי:</span>
                            </div>
                            <span class="text-xs font-extrabold text-emerald-800" id="trackerStats">נצרך: 0 גרם מתוך 0 גרם</span>
                        </div>
                        <div class="w-full bg-emerald-200/50 h-3 rounded-full overflow-hidden">
                            <div id="trackerProgressBar" class="bg-emerald-600 h-full rounded-full transition-all duration-300" style="width: 0%"></div>
                        </div>
                        <p class="text-[10px] text-emerald-700/80 mt-1.5 font-medium">סמן וי (V) ליד הארוחות שאכלת למטה כדי לראות את כמות החלבון מתעדכנת!</p>
                    </div>
                </div>

                <!-- Meals Schedule -->
                <div class="p-6">
                    <h3 class="text-stone-500 text-xs font-bold uppercase tracking-wider mb-6 flex items-center gap-1.5">
                        <i data-lucide="clock" class="w-4 h-4 text-stone-400"></i>
                        סדר ארוחות יומי וטיפים להכנה טעימה ורכה
                    </h3>

                    <div id="mealsContainer" class="space-y-6 relative border-r-2 border-dashed border-stone-200 pr-5 mr-3">
                        <!-- Meals generated by JS dynamically -->
                    </div>
                </div>

                <!-- Rules / Tips Banner inside card -->
                <div class="bg-brand-50/50 p-6 border-t border-stone-100 flex flex-col md:flex-row items-start gap-4">
                    <div class="p-2.5 bg-amber-400/20 text-amber-700 rounded-2xl">
                        <i data-lucide="lightbulb" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-stone-800 text-sm">חוקי הזהב לתזונת ספורט בריאטרית:</h4>
                        <ul class="text-xs text-stone-500 mt-1.5 space-y-1.5 list-disc list-inside">
                            <li><strong>חשיבות הלעיסה:</strong> תלעס כל ביס 25-30 פעמים עד שהמרקם פירה לגמרי.</li>
                            <li><strong>משך הארוחה:</strong> שבו לאכול בנחת. ארוחה צריכה לקחת בערך 20-30 דקות.</li>
                            <li><strong>לעולם אל תשתה מים יחד עם האוכל.</strong> זה דוחף את האוכל החוצה מהר מדי ומותח את הקיבה.</li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>

    </div>

    <script>
        // Array of menus featuring creative, high protein, completely kosher recipes.
        // Processed meats (such as pastrami, sausages, etc.) are NOT used.
        // Dynamic times are calculated via relative offsets in hours since wake-up time.
        const menus = [
            {
                name: "תפריט א' - הקלאסי והעשיר",
                macros: { cal: 1172, pro: 119, carb: 70, fat: 42 },
                meals: [
                    { offsetHours: 0.5, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת בוקר", protein: 20, desc: "חביתה מ-2 ביצים גדולות + 2 יחידות לחמית עם 3 כפות קוטג' 5% + מלפפון קלוף.", tip: "בשביל חביתה רכה ולא יבשה, תוסיף כף מים לביצים לפני הטריפה ותכסה את המחבת בזמן הטיגון." },
                    { offsetHours: 3.0, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת ביניים בוקר", protein: 21, desc: "גביע יוגורט חלבון (GO/PRO) + 5 שקדים בצד.", tip: "אם קשה לך לאכול שקדים יבשים, השהה אותם בכוס מים חמים לכמה דקות וקלף את הקליפה. הם יהיו רכים וקלים לעיכול." },
                    { offsetHours: 6.0, kosherType: "meat", kosherLabel: "בשרי", name: "ארוחת צהריים", protein: 41, desc: "חזה עוף פרוס דק (130 גרם) עשוי במחבת נון-סטיק + רבע כרוב אפוי בתנור.", tip: "כדי שחזה העוף יישאר עסיסי בטירוף במחבת, טגן אותו עם מכסה סגור על אש בינונית רק 3 דקות לכל צד." },
                    { offsetHours: 8.5, kosherType: "parve", kosherLabel: "פרווה", name: "ארוחת ביניים אחה\"צ", protein: 24, desc: "קופסת טונה קטנה מסוננת + פרוסת לחם מלא קלויה בטוסטר + חצי אבוקדו בינוני.", tip: "תמעך את הטונה יחד עם האבוקדו, מעט מיץ לימון ומלח. המרקם הקרמי הופך את הטונה לקלה במיוחד לבליעה." },
                    { offsetHours: 11.0, kosherType: "parve", kosherLabel: "פרווה", name: "ארוחת ערב", protein: 13, desc: "שקשוקה קלה מביצה אחת שלמה + חלבון ביצה נוסף (מבושלים היטב ברוטב עגבניות) + 2 יחידות לחמית.", tip: "בישול השקשוקה עם מכסה סגור יבטיח שהחלמון יתקשה לגמרי, דבר שמקל על העיכול של מנותחים." }
                ]
            },
            {
                name: "תפריט ב' - שגרת דג עסיסית ומחוזקת",
                macros: { cal: 1232, pro: 111, carb: 80, fat: 51 },
                meals: [
                    { offsetHours: 0.5, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת בוקר", protein: 21, desc: "גביע יוגורט חלבון 3% עם כף שטוחה גרנולה וחצי כפית דבש.", tip: "תן לגרנולה לשבת בתוך היוגורט לפחות 3 דקות לפני האכילה כדי שתרכך לחלוטין ולא תציק בקיבה." },
                    { offsetHours: 3.0, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת ביניים בוקר", protein: 23, desc: "חביתה מ-2 ביצים + פרוסת לחם קלויה עם 2 כפות קוטג' 5% ומעט בולגרית מפוררת.", tip: "קצץ מעט שמיר או פטרוזיליה לתוך הביצים לקבלת טעם רענן ומקצועי של בית קפה." },
                    { offsetHours: 6.0, kosherType: "parve", kosherLabel: "פרווה", name: "ארוחת צהריים", protein: 31, desc: "130 גרם פילה סלמון או אמנון אפוי בתנור + 3 כפות פירה תפוחי אדמה רך.", tip: "אפה את הדג כשהוא מכוסה בנייר כסף ב-180 מעלות למשך 12 דקות בלבד. הדג יישאר לח, נימוח ומתפרק בקלות." },
                    { offsetHours: 8.5, kosherType: "parve", kosherLabel: "פרווה", name: "ארוחת ביניים אחה\"צ", protein: 24, desc: "קופסת טונה קטנה מסוננת + חצי אבוקדו מועך עם לימון ומלח + פרוסת לחם מלא קלויה.", tip: "קפוץ את פרוסת הלחם בטוסטר עד שהיא פריכה - לחם קלוי ופריך (צנים) מתעכל בקיבה מקוצרת הרבה יותר טוב מלחם רך שנוטה להידבק." },
                    { offsetHours: 11.0, kosherType: "parve", kosherLabel: "פרווה", name: "ארוחת ערב", protein: 12, desc: "סלט ביצים מביצה קשה וחלמון נוסף מעוכים עם כפית מיונז לייט + 2 לחמיות דקות.", tip: "ערבב כפית חרדל חריף עם המיונז כדי לתת עומק לטעם בלי להכביד." }
                ]
            },
            {
                name: "תפריט ג' - קציצות בשר רכות ברוטב",
                macros: { cal: 1027, pro: 95, carb: 80, fat: 35 },
                meals: [
                    { offsetHours: 0.5, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת בוקר", protein: 21, desc: "גביע מעדן חלבון (GO/PRO) וניל או שוקולד + 5 חצאי אגוזי מלך בצד.", tip: "מעדני החלבון נהדרים לסגירת הפינה המתוקה של הבוקר בלי להקפיץ את הסוכר." },
                    { offsetHours: 3.0, kosherType: "dairy", kosherLabel: "חלבי", name: "ארוחת ביניים בוקר", protein: 13, desc: "פרוסת לחם מלא קלויה (טוסט) עם פרוסת גבינה צהובה 9% מומסת + מלפפון קלוף.", tip: "הסרת קליפת המלפפון חיונית למניעת גזים ותחושת נפיחות אצל מנותחים." },
                    { offsetHours: 6.0, kosherType: "meat", kosherLabel: "בשרי", name: "ארוחת צהריים", protein: 26, desc: "3 קציצות בקר או עוף רכות שבושלו ברוטב עגבניות פשוט + 3 כפות פתיתים שספגו מהרוטב.", tip: "כדי שהקציצות יהיו רכות במיוחד, תגרד פנימה בצל שלם סחוט - המיצים של הבצל שומרים על מרקם קטיפתי ורך." },
